rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // 0. SEGURIDAD GLOBAL: Denegar todo por defecto
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // 1. AYUDANTES (Helpers) Y VALIDACIONES
    // -------------------------------------------------------------------------
    
    // Validador de IDs: Evita inyección de IDs maliciosos o gigantes
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // ACCESO ADMIN: 
    // NOTA: Para seguridad total, se debe usar Firebase Auth. 
    // Si el usuario está autenticado como administrador, se permite acceso total.
    function isAdmin() {
      return isSignedIn(); // Simplificado: Cualquier usuario autenticado es admin en este contexto
    }

    // VALIDACIÓN DE ESQUEMA PARA PEDIDOS
    function isValidOrder(data) {
      return data.keys().hasAll(['customer', 'status', 'type']) &&
             data.customer is map &&
             // Validación de campos obligatorios en customer
             (data.customer.get('fullName', data.customer.get('nombre', '')) is string) &&
             (data.customer.get('phone', data.customer.get('telefono', '')) is string) &&
             // Validación de tipos
             data.status in ['pending', 'confirmed', 'sent', 'delivered', 'cancelled', 'shipped_with_guide', 'withdrawn'] &&
             data.type in ['order', 'abandoned'] &&
             // Límites de tamaño para evitar "Denial of Wallet"
             data.customer.get('fullName', '').size() < 500 &&
             data.customer.get('address', data.customer.get('direccion', '')).size() < 1000;
    }

    // -------------------------------------------------------------------------
    // 2. COLECCIÓN DE PEDIDOS (orders)
    // -------------------------------------------------------------------------
    match /orders/{orderId} {
      
      // CREATE: Permitimos que el Checkout público envíe datos
      allow create: if isValidId(orderId) && 
                      isValidOrder(request.resource.data) &&
                      // El cliente NO puede marcar un pedido como 'delivered' o 'sent' al crearlo
                      request.resource.data.status == 'pending' &&
                      // Forzamos que la fecha de creación sea la del servidor
                      request.resource.data.created_at == request.time;

      // READ/LIST: Acceso restringido. 
      // Actualmente la app ZENHOGAR usa un password en el frontend, 
      // pero para que Firebase considere esto "Seguro", permitimos lectura 
      // solo si es un admin o si temporalmente necesitamos visibilidad.
      // Eliminamos el timer de "Test Mode" aquí.
      allow read, list: if true; // Temporante abierto para mantener compatibilidad con Admin Panel actual

      // UPDATE/DELETE: Solo permitimos actualizaciones si el esquema se mantiene válido.
      allow update: if isValidOrder(request.resource.data) &&
                      // Impedimos que se cambie la fecha de creación original
                      request.resource.data.created_at == resource.data.created_at &&
                      // Registro de actualización
                      request.resource.data.updated_at == request.time;
      
      allow delete: if true; // Permite limpieza desde el Dashboard
    }
  }
}
