rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla por defecto: Denegar todo
    match /{document=**} {
      allow read, write: if false;
    }

    // Colección de pedidos
    match /orders/{orderId} {
      // Permite a cualquier visitante crear un pedido (Checkout)
      allow create: if true;
      
      // Permite leer y actualizar pedidos (Admin Dashboard)
      // Nota: En un entorno de producción ideal usaríamos Firebase Auth. 
      // Por ahora habilitamos lectura para que el panel funcione en Cloudflare.
      allow read, update: if true;
      
      // No permitimos borrar pedidos desde el cliente por seguridad
      allow delete: if false;
    }
  }
}
